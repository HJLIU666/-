/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #d6b911 0%, #d39e0c 50%, #be5417 100%);
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 80rpx;
  margin-bottom: 80rpx;
}

.hero-icon {
  width: 180rpx;
  height: 180rpx;
  background: rgb(241, 187, 116);
  border-radius: 90rpx;
  padding: 30rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-top: 40rpx;
}

.hero-subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 16rpx;
}

.description {
  background: rgba(255,255,255,0.15);
  border-radius: 32rpx;
  padding: 40rpx;
  margin: 40rpx 0;
}

.desc-text {
  display: block;
  color: white;
  font-size: 30rpx;
  margin: 16rpx 0;
}

.desc-text-english {
  display: block;
  color: #ffffff;
  font-size: 20rpx;
  margin: 16rpx 0;
}

.start-btn {
  background: #7e8b0a;
  color: #ffffff;
  font-size: 50rpx;
  font-weight: bold;
  border-radius: 60rpx;
  margin: 40rpx 0;
  padding: 28rpx 0;
}

.start-btn::after {
  border: none;
}

.safety-note {
  background: rgba(0,0,0,0.5);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-top: 80rpx;
}

.note-title {
  display: block;
  color: #FF9800;
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.note-title-english {
  display: block;
  color: #999;
  font-size: 20rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.note-text {
  display: block;
  color: rgba(255,255,255,0.8);
  font-size: 26rpx;
  margin-bottom: 16rpx;
}

.note-text-english{
  display: block;
  color: #999;
  font-size: 20rpx;
}