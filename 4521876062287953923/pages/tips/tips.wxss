/* pages/tips/tips.wxss */
.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 30rpx;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #2E7D32;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 12rpx;
  border-left: 8rpx solid #4CAF50;
}

.card {
  background: white;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.tip {
  display: block;
  font-size: 30rpx;
  color: #555;
  line-height: 2;
}

.tip-english {
  display: block;
  font-size: 20rpx;
  color: #999;
  line-height: 2;
}